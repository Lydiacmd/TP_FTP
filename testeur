#!/bin/bash
# =============================================================================
#  testeur.sh — Tests automatiques du projet FTP
#  Belabbas Lydia & Zaidi Arris 
# =============================================================================

SERVEUR="localhost"
SERVER_DIR="./server_files"
CLIENT_DIR="./client_files"
TRANSFER_TMP="./client_files/transfer.tmp"

BIN_CLIENT="./fihcierClient"
BIN_MAITRE="./serveurMaitre"
BIN_ESCLAVE="./serveurEsclave"

GREEN="\033[0;32m"; RED="\033[0;31m"; YELLOW="\033[1;33m"
CYAN="\033[0;36m"; BOLD="\033[1m"; RESET="\033[0m"

PASS=0; FAIL=0; TOTAL=0

print_header() {
    echo ""
    echo -e "${CYAN}${BOLD}══════════════════════════════════════════════════${RESET}"
    echo -e "${CYAN}${BOLD}  $1${RESET}"
    echo -e "${CYAN}${BOLD}══════════════════════════════════════════════════${RESET}"
}

check() {
    local desc="$1"; local result="$2"
    TOTAL=$((TOTAL + 1))
    if [ "$result" -eq 0 ]; then
        echo -e "  ${GREEN}[OK]${RESET}   $desc"; PASS=$((PASS + 1))
    else
        echo -e "  ${RED}[FAIL]${RESET} $desc"; FAIL=$((FAIL + 1))
    fi
}

run_client() {
    echo -e "$1" | timeout 5 $BIN_CLIENT $SERVEUR 2>&1
}

cleanup() {
    kill $PID_MAITRE $PID_ESCLAVE1 $PID_ESCLAVE2 2>/dev/null
    wait 2>/dev/null
}

# ─── Préparation ──────────────────────────────────────────────────────────────
print_header "Préparation de l'environnement"
mkdir -p "$SERVER_DIR" "$CLIENT_DIR"
echo "Bonjour monde, ceci est un fichier texte de test." > "$SERVER_DIR/fichier.txt"
dd if=/dev/urandom bs=1024 count=512 of="$SERVER_DIR/image.png" 2>/dev/null
rm -f "$CLIENT_DIR"/* "$TRANSFER_TMP"
echo -e "  ${YELLOW}Fichiers de test créés dans $SERVER_DIR${RESET}"

# ─── Démarrage ────────────────────────────────────────────────────────────────
print_header "Démarrage Maître / Esclaves"
$BIN_ESCLAVE 2122 & PID_ESCLAVE1=$!
$BIN_ESCLAVE 2123 & PID_ESCLAVE2=$!
sleep 1
$BIN_MAITRE $SERVEUR & PID_MAITRE=$!
sleep 1

if kill -0 $PID_MAITRE 2>/dev/null; then
    echo -e "  ${GREEN}Maître    démarré  (PID $PID_MAITRE)${RESET}"
    echo -e "  ${GREEN}Esclave 1 démarré  (PID $PID_ESCLAVE1, port 2122)${RESET}"
    echo -e "  ${GREEN}Esclave 2 démarré  (PID $PID_ESCLAVE2, port 2123)${RESET}"
else
    echo -e "  ${RED}Impossible de démarrer le maître — abandon${RESET}"
    cleanup; exit 1
fi

# ─── Test 1 : get fichier texte ───────────────────────────────────────────────
print_header "Test 1 — get fichier.txt"
rm -f "$CLIENT_DIR/fichier.txt"
OUT=$(run_client "get fichier.txt\nbye")
echo "$OUT" | grep -q "Transfer successfully complete"
check "get fichier.txt : transfert réussi" $?
[ -f "$CLIENT_DIR/fichier.txt" ]
check "get fichier.txt : fichier créé localement" $?

# ─── Test 2 : intégrité MD5 ──────────────────────────────────────────────────
print_header "Test 2 — get image.png (intégrité MD5)"
rm -f "$CLIENT_DIR/image.png"
run_client "get image.png\nbye" > /dev/null
MD5_SRC=$(md5sum "$SERVER_DIR/image.png" | awk '{print $1}')
MD5_DST=$(md5sum "$CLIENT_DIR/image.png"  | awk '{print $1}')
[ "$MD5_SRC" = "$MD5_DST" ]
check "image.png : MD5 source = MD5 destination" $?

# ─── Test 3 : fichier inexistant ─────────────────────────────────────────────
print_header "Test 3 — get fichier inexistant"
OUT=$(run_client "get fichier_qui_nexiste_pas.txt\nbye")
echo "$OUT" | grep -qi "erreur\|introuvable\|not found\|-1"
check "get inexistant : message d'erreur affiché" $?

# ─── Test 4 : ls ─────────────────────────────────────────────────────────────
print_header "Test 4 — ls"
OUT=$(run_client "ls\nbye")
echo "$OUT" | grep -q "fichier.txt"
check "ls : fichier.txt visible dans la liste" $?

# ─── Test 5 : put sans login ──────────────────────────────────────────────────
print_header "Test 5 — put sans authentification"
echo "contenu test" > "$CLIENT_DIR/upload_test.txt"
OUT=$(run_client "put upload_test.txt\nbye")
echo "$OUT" | grep -qi "erreur\|autoris\|interdit\|-2\|non"
check "put sans login : accès refusé (code -2)" $?

# ─── Test 6 : login correct ───────────────────────────────────────────────────
print_header "Test 6 — login admin 1809"
OUT=$(run_client "login admin 1809\nbye")
echo "$OUT" | grep -qi "réussie\|success\|authentifi"
check "login admin 1809 : authentification réussie" $?

# ─── Test 7 : login incorrect ─────────────────────────────────────────────────
print_header "Test 7 — login mauvais mot de passe"
OUT=$(run_client "login admin mauvais\nbye")
echo "$OUT" | grep -qi "erreur\|incorrect\|-1"
check "login mauvais MDP : erreur signalée" $?

# ─── Test 8 : put après login ─────────────────────────────────────────────────
print_header "Test 8 — put après authentification"
echo "fichier envoyé par le client" > "$CLIENT_DIR/upload_test.txt"
OUT=$(run_client "login admin 1809\nput upload_test.txt\nbye")
echo "$OUT" | grep -qi "succès\|success\|envoyé"
check "put après login : envoi accepté" $?
[ -f "$SERVER_DIR/upload_test.txt" ]
check "put après login : fichier présent sur le serveur" $?

# ─── Test 9 : rm apres login ──────────────────────────────────────────────────
print_header "Test 9 — rm après authentification"
OUT=$(run_client "login admin 1809\nrm upload_test.txt\nbye")
echo "$OUT" | grep -qi "supprimé\|success\|ok"
check "rm après login : suppression acceptée" $?
[ ! -f "$SERVER_DIR/upload_test.txt" ]
check "rm après login : fichier absent du serveur" $?

# ─── Test 10 : bye ────────────────────────────────────────────────────────────
print_header "Test 10 — déconnexion propre (bye)"
echo -e "bye" | timeout 5 $BIN_CLIENT $SERVEUR > /dev/null 2>&1
check "bye : client se termine sans erreur" $?

# ─── Test 11 : 5 clients simultanés ──────────────────────────────────────────
print_header "Test 11 — 5 clients simultanés"
PIDS_CLIENTS=()
for i in $(seq 1 5); do
    run_client "get fichier.txt\nbye" > "/tmp/ftp_client_$i.txt" &
    PIDS_CLIENTS+=($!)
done
for pid in "${PIDS_CLIENTS[@]}"; do wait $pid; done
OK_COUNT=0
for i in $(seq 1 5); do
    grep -q "Transfer successfully complete" "/tmp/ftp_client_$i.txt" \
        && OK_COUNT=$((OK_COUNT + 1))
done
[ "$OK_COUNT" -eq 5 ]
check "5 clients simultanés : tous ont reçu le fichier ($OK_COUNT/5)" $?

# ─── Test 12 : reprise après crash ───────────────────────────────────────────
print_header "Test 12 — reprise après crash client"
echo "image.png 102400" > "$TRANSFER_TMP"
dd if=/dev/urandom bs=1024 count=100 of="$CLIENT_DIR/image.png" 2>/dev/null
OUT=$(run_client "get image.png\nbye")
echo "$OUT" | grep -qi "interrompu\|reprise\|offset\|Transfer successfully"
check "reprise crash : transfert détecté et repris" $?
[ ! -f "$TRANSFER_TMP" ]
check "reprise crash : TRANSFER_TMP supprimé après succès" $?

# ─── Test 13 : Round-Robin ────────────────────────────────────────────────────
print_header "Test 13 — Round-Robin entre les esclaves"
OUT1=$(run_client "get fichier.txt\nbye" 2>&1)
OUT2=$(run_client "get fichier.txt\nbye" 2>&1)
echo "$OUT1" | grep -q "Transfer successfully complete"; R1=$?
echo "$OUT2" | grep -q "Transfer successfully complete"; R2=$?
[ $R1 -eq 0 ] && [ $R2 -eq 0 ]
check "Round-Robin : les deux clients ont reçu le fichier" $?

# ─── Test 14 : panne d'un esclave ─────────────────────────────────────────────
print_header "Test 14 — panne d'un esclave"
kill $PID_ESCLAVE1 2>/dev/null
sleep 1
OUT=$(run_client "get fichier.txt\nbye")
echo "$OUT" | grep -q "Transfer successfully complete"
check "panne esclave 1 : transfert réussi via esclave 2" $?

# ─── Test 15 : SIGINT maître ──────────────────────────────────────────────────
print_header "Test 15 — arrêt propre du maître (Ctrl+C)"
kill -INT $PID_MAITRE 2>/dev/null
sleep 1
kill -0 $PID_MAITRE 2>/dev/null
[ $? -ne 0 ]
check "Ctrl+C maître : processus terminé proprement" $?

# =============================================================================
#  Résumé
# =============================================================================

cleanup

echo ""
echo -e "${CYAN}${BOLD}══════════════════════════════════════════════════${RESET}"
echo -e "${BOLD}  RÉSULTATS FINAUX${RESET}"
echo -e "${CYAN}${BOLD}══════════════════════════════════════════════════${RESET}"
echo -e "  Total    : ${BOLD}$TOTAL${RESET}"
echo -e "  ${GREEN}Réussis  : $PASS${RESET}"
if [ "$FAIL" -gt 0 ]; then
    echo -e "  ${RED}Échoués  : $FAIL${RESET}"
else
    echo -e "  Échoués  : 0"
fi
echo -e "${CYAN}${BOLD}══════════════════════════════════════════════════${RESET}"
echo ""

[ "$FAIL" -eq 0 ]